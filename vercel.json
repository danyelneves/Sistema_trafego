{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ],
  "crons": [
    {
      "path": "/api/sentinel/cron",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/skynet/cron",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/lazarus/cron",
      "schedule": "*/15 * * * *"
    }
  ]
}
