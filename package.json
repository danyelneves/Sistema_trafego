{
  "name": "nexus-os",
  "version": "1.0.0",
  "description": "Nexus OS — Sistema operacional de IA para vendas, tráfego e automação multi-tenant",
  "main": "server.js",
  "scripts": {
    "start": "node --no-warnings server.js",
    "dev": "node --no-warnings --watch server.js",
    "seed": "node --no-warnings db/seed.js",
    "reset": "node --no-warnings db/reset.js",
    "db:migrate": "node --no-warnings db/migrate.js",
    "test": "node tests/unit.js",
    "test:smoke": "node tests/smoke.js",
    "test:smoke:prod": "DOMAIN=https://nexusagencia.app node tests/smoke.js",
    "docs:api": "node scripts/gen-api-docs.js",
    "docs:schema": "node scripts/gen-schema-docs.js",
    "docs:gen": "npm run docs:api && npm run docs:schema",
    "vercel-build": "echo Build OK"
  },
  "keywords": [
    "nexus-os",
    "ai-saas",
    "marketing-automation",
    "multi-tenant",
    "vendas-ia"
  ],
  "author": "Nexus",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@google/generative-ai": "^0.24.1",
    "@sentry/node": "^8.55.2",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "axios": "^1.15.2",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.4.1",
    "jsdom": "^29.1.0",
    "jsonwebtoken": "^9.0.2",
    "mercadopago": "^2.12.0",
    "nodemailer": "^8.0.5",
    "openai": "^6.35.0",
    "pg": "^8.11.3",
    "stripe": "^22.1.0"
  }
}
