{
  "manifest_version": 3,
  "name": "Nexus Spy",
  "version": "1.0.0",
  "description": "Salve anúncios da Biblioteca de Anúncios do Facebook direto no Raio-X do Nexus OS.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "https://www.facebook.com/ads/library/*",
    "https://*.vercel.app/*",
    "http://localhost:3000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Nexus Spy"
  },
  "content_scripts": [
    {
      "matches": ["https://www.facebook.com/ads/library/*"],
      "js": ["content.js"]
    }
  ]
}
