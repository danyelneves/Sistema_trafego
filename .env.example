# Copie este arquivo para .env e ajuste conforme necessário

PORT=3000

# ────────── SEGURANÇA ──────────────────────────────────────
# Altere para uma string longa aleatória em produção:
#   openssl rand -hex 32
JWT_SECRET=troque-este-segredo-em-producao-use-algo-longo-e-aleatorio

# Duração do token de sessão
JWT_EXPIRES=7d

# Ambiente: 'production' habilita cookie secure
NODE_ENV=development

# ────────── SEED ───────────────────────────────────────────
# Credenciais do usuário admin inicial (apenas no primeiro seed)
ADMIN_USER=admin
ADMIN_PASS=maranet2026

# ────────── LOGS ───────────────────────────────────────────
# Número de arquivos de log diários a manter
LOG_KEEP_DAYS=30

# ────────── SUPABASE / POSTGRESQL ──────────────────────────
# Obtenha em: https://supabase.com/dashboard → Settings → Database → Connection string (URI)
# Use a string com "Transaction" pooler na porta 6543 para Vercel Serverless:
#
DATABASE_URL=postgresql://postgres.[ref]:[senha]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

# Supabase URL e chave anon (se usar @supabase/supabase-js no frontend):
SUPABASE_URL=https://[ref].supabase.co
SUPABASE_ANON_KEY=eyJ...

# ────────── VERCEL CRON ────────────────────────────────────
# Chave secreta para proteger o endpoint /api/cron/alerts.
# Crie com: openssl rand -hex 16
# Configure também nas env vars da Vercel em: Settings → Environment Variables
CRON_SECRET=sua-chave-secreta-do-cron-aqui

# ────────── SMTP — GMAIL ───────────────────────────────────
# Habilita alertas de KPI por e-mail.
# No Gmail: ative 2FA → Conta Google → Segurança → Senhas de app
#
SMTP_USER=seu@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
SMTP_FROM=Maranet Tráfego <seu@gmail.com>

# ────────── GOOGLE ADS API ─────────────────────────────────
# Obtenha em: https://developers.google.com/google-ads/api/docs/get-started/introduction
#
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=

# ────────── META MARKETING API ─────────────────────────────
# Obtenha em: https://developers.facebook.com/docs/marketing-api
#
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=act_

# ────────── SEGURANÇA E AUDITORIA (NEXUS OS) ───────────────
# Segredo HMAC do Webhook de Pagamentos (Mercado Pago)
MP_WEBHOOK_SECRET=

# ID da Conta Mercado Pago (Colecionador)
MP_COLLECTOR_ID=

# Upstash Redis (Rate Limiter Serverless)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ────────── OBSERVABILIDADE ─────────────────────────────────
# Sentry: captura automática de erros em produção. Cria projeto Node.js em
# https://sentry.io (free tier) e cola o DSN abaixo. Sem DSN, vira no-op.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Nível mínimo de log: debug | info | warn | error (default: info em prod, debug em dev)
LOG_LEVEL=
